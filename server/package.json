{
  "name": "portfel-server",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsc-watch --onSuccess \"node dist/index.js\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/static": "8.0.1",
    "better-sqlite3": "11.5.0",
    "fastify": "5.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.11",
    "@types/node": "22.9.0",
    "tsc-watch": "6.2.1",
    "typescript": "5.6.3"
  },
  "allowScripts": {
    "better-sqlite3@11.5.0": true
  }
}
